{
  "permissions": {
    "allow": [
      "Bash(nc:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(docker pull:*)",
      "Bash(gh run:*)",
      "Bash(podman logs:*)",
      "Bash(podman exec:*)",
      "WebFetch(domain:docs.haproxy.org)",
      "Bash(gh search:*)",
      "Bash(gh api:*)",
      "Read(//usr/bin/**)",
      "Read(//usr/local/bin/**)",
      "WebFetch(domain:www.haproxy.org)",
      "WebFetch(domain:git.haproxy.org)",
      "Bash(podman run:*)",
      "Read(//tmp/**)",
      "Bash(podman build:*)",
      "Bash(podman rm:*)",
      "Bash(dig +short:*)",
      "Bash(podman ps:*)",
      "Bash(podman inspect:*)",
      "Bash(podman images:*)",
      "Bash(podman rmi:*)",
      "Bash(podman port:*)",
      "Bash(podman start:*)",
      "Bash(break)",
      "Bash(podman stop:*)",
      "Bash(echo \"Exit: $?\")",
      "Bash(podman events:*)",
      "Bash(timeout 10 bash -c 'echo | socat - TCP4:109.110.170.208:29323,connect-timeout=5')",
      "Bash(timeout 10 bash -c 'echo | socat - TCP4:89.164.18.160:9005,connect-timeout=5')",
      "Bash(timeout 5 bash -c 'cat < /dev/tcp/109.110.170.208/29323')",
      "Bash(timeout 5 bash -c 'cat < /dev/tcp/89.164.18.160/9005')",
      "Bash(timeout 5 bash -c 'echo > /dev/tcp/109.110.170.208/29323')",
      "Bash(timeout 5 bash -c 'echo > /dev/tcp/89.164.18.160/9005')",
      "Bash(timeout 10 bash -c 'echo > /dev/tcp/89.164.18.160/9005')"
    ]
  }
}
