{
  "permissions": {
    "allow": [
      "Bash(nc:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(docker pull:*)",
      "Bash(gh run:*)",
      "Bash(podman logs:*)",
      "Bash(podman exec:*)",
      "WebFetch(domain:docs.haproxy.org)",
      "Bash(gh search:*)",
      "Bash(gh api:*)",
      "Read(//usr/bin/**)",
      "Read(//usr/local/bin/**)",
      "WebFetch(domain:www.haproxy.org)",
      "WebFetch(domain:git.haproxy.org)"
    ]
  }
}
