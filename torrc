DataDirectory /app/data/tor
UseBridges 1

# Tor 0.4.8+ default Conflux + the default NumPrimaryGuards 3 are exactly
# what we want: with the 3 bridges start.sh requires, every onion-service
# circuit gets the 2-link-disjoint Conflux pair, halving cold-query latency
# vs single-circuit. (Earlier images set ConfluxEnabled 0 / NumPrimaryGuards 2
# to make 2-bridge configs survive — that workaround is gone now that the
# image requires 3 bridges.)

# SOCKS proxy: explicit loopback bind; HAProxy connects here for SOCKS4 routing.
SocksPort 127.0.0.1:9050
# No ControlPort — no authenticated management channel is exposed.

ClientTransportPlugin obfs4 exec /usr/bin/lyrebird

# Cloudflare's hidden DNS resolver returns this RFC1918 sentinel IP when
# clients query it; we MapAddress it back to the .onion before connecting.
# The rewrite is purely client-side — nothing leaks to the network.
MapAddress 10.192.0.1 dns4torpnlfs2ifuz2s2yf3fc7rdmsbhm6rw75euj35pac6ap25zgqad.onion

# Tor 0.4.9+ rejects SOCKS connections to RFC1918 destinations BEFORE applying
# MapAddress, so haproxy's `socks4 127.0.0.1:9050` target of 10.192.0.1:853 is
# refused with "SOCKS4 Proxy deny the request" even though MapAddress would
# rewrite it to the onion. Disable the early reject for the SOCKS path; the
# only RFC1918 destination we ever connect to here is 10.192.0.1, which the
# MapAddress above redirects to a .onion — nothing escapes the loopback.
ClientRejectInternalAddresses 0
